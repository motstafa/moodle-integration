APP_NAME="Moodle Admin Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ─── Moodle Web Services ───────────────────────────────────────────────────────
# Base URL of your Moodle instance, no trailing slash.
# See config/services.php for how these values are consumed.
MOODLE_URL=
# Web service token — fill in .env only, NEVER commit a real value here.
MOODLE_TOKEN=
# Response cache TTL in seconds (default 600 = 10 min).
MOODLE_CACHE_TTL=600
# ──────────────────────────────────────────────────────────────────────────────

# Frontend origin allowed by CORS
FRONTEND_URL=http://localhost:3000

# Secret for POST /api/cache/flush
REFRESH_SECRET=
